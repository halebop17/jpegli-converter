#!/bin/bash
# Launcher for TIFF → jpegli Converter
# This script is the executable inside the .app bundle.

# Resolve the project root: three levels up from Contents/MacOS/
SCRIPT_PATH="$(cd "$(dirname "$0")" && pwd)"
PROJECT_DIR="$(cd "$SCRIPT_PATH/../../.." && pwd)"

PYTHON="$PROJECT_DIR/.venv/bin/python3"
APP="$PROJECT_DIR/converter_app.py"

# Sanity checks
if [ ! -f "$PYTHON" ]; then
    osascript -e 'display alert "TIFF Converter" message "Python venv not found.\n\nRun from the project folder:\n  python3 -m venv .venv\n  .venv/bin/pip install Pillow numpy" as critical'
    exit 1
fi

if [ ! -f "$APP" ]; then
    osascript -e 'display alert "TIFF Converter" message "converter_app.py not found next to this .app bundle." as critical'
    exit 1
fi

exec "$PYTHON" "$APP"
